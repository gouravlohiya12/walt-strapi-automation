<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BrightFlow — AI-Powered Project Management</title>
  <meta name="description" content="BrightFlow is an AI-powered project management tool. Work smarter, ship faster.">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50: '#eff6ff',
              100: '#dbeafe',
              200: '#bfdbfe',
              300: '#93c5fd',
              400: '#60a5fa',
              500: '#3b82f6',
              600: '#2563EB',
              700: '#1d4ed8',
              800: '#1e40af',
              900: '#1e3a8a',
            }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-white text-gray-900">

  <!-- Header -->
  <header class="border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-sm">B</span>
        </div>
        <span class="text-xl font-bold text-gray-900">BrightFlow</span>
      </a>
    </div>
  </header>

  <!-- Hero -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="inline-block px-4 py-1.5 bg-brand-50 text-brand-600 text-sm font-medium rounded-full mb-6">
        Work smarter, ship faster.
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">BrightFlow Landing Pages</h1>
      <p class="text-lg text-gray-500 mb-4">
        <%= pages.length %> published landing page<%= pages.length !== 1 ? 's' : '' %>
      </p>
    </div>
  </section>

  <!-- Pages List -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-6">
      <% if (pages.length === 0) { %>
        <div class="text-center py-16 bg-gray-50 rounded-2xl">
          <p class="text-gray-400 text-lg">No landing pages yet.</p>
          <p class="text-gray-400 text-sm mt-2">Run the generation script to create pages.</p>
        </div>
      <% } else { %>
        <div class="grid gap-4">
          <% pages.forEach(function(page) { %>
            <a href="/<%= page.slug %>" class="block p-6 bg-white border border-gray-200 rounded-xl hover:border-brand-300 hover:shadow-md transition group">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <h2 class="text-lg font-semibold text-gray-900 group-hover:text-brand-600 transition truncate">
                    <%= page.h1 %>
                  </h2>
                  <% if (page.subheadline) { %>
                    <p class="text-gray-500 mt-1 truncate"><%= page.subheadline %></p>
                  <% } %>
                  <div class="flex items-center gap-3 mt-3">
                    <span class="text-xs px-2.5 py-1 bg-brand-50 text-brand-600 rounded-full font-medium"><%= page.keyword %></span>
                    <span class="text-xs text-gray-400">/<%= page.slug %></span>
                  </div>
                </div>
                <span class="text-gray-300 group-hover:text-brand-600 transition text-xl">&rarr;</span>
              </div>
            </a>
          <% }); %>
        </div>
      <% } %>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-gray-100 py-8">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-sm text-gray-400">&copy; 2026 BrightFlow. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>
