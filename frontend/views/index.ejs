<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nexora — AI-Powered Customer Support</title>
  <meta name="description" content="Nexora is an AI-powered customer support platform. Support that scales with you.">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50: '#f5f3ff',
              100: '#ede9fe',
              200: '#ddd6fe',
              300: '#c4b5fd',
              400: '#a78bfa',
              500: '#8b5cf6',
              600: '#7C3AED',
              700: '#6d28d9',
              800: '#5b21b6',
              900: '#4c1d95',
            }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-white text-gray-900 antialiased">

  <!-- Header -->
  <header class="border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <div class="w-9 h-9 bg-gradient-to-br from-brand-600 to-brand-800 rounded-xl flex items-center justify-center shadow-md shadow-brand-600/20">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        </div>
        <span class="text-xl font-bold text-gray-900 tracking-tight">Nexora</span>
      </a>
    </div>
  </header>

  <!-- Hero -->
  <section class="py-20 bg-gradient-to-b from-brand-50/50 to-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-brand-200 text-brand-700 text-sm font-medium rounded-full mb-6 shadow-sm">
        <span class="w-2 h-2 bg-green-500 rounded-full"></span>
        Support that scales with you.
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4 tracking-tight">Nexora Landing Pages</h1>
      <p class="text-lg text-gray-500 mb-4">
        <%= pages.length %> published landing page<%= pages.length !== 1 ? 's' : '' %>
      </p>
    </div>
  </section>

  <!-- Pages List -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-6">
      <% if (pages.length === 0) { %>
        <div class="text-center py-16 bg-gray-50 rounded-2xl border border-gray-100">
          <p class="text-gray-400 text-lg">No landing pages yet.</p>
          <p class="text-gray-400 text-sm mt-2">Run the generation script to create pages.</p>
        </div>
      <% } else { %>
        <div class="grid gap-4">
          <% pages.forEach(function(page) { %>
            <a href="/<%= page.slug %>" class="block p-6 bg-white border border-gray-200 rounded-xl hover:border-brand-300 hover:shadow-lg hover:shadow-brand-600/5 transition-all duration-300 group">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <h2 class="text-lg font-semibold text-gray-900 group-hover:text-brand-600 transition truncate">
                    <%= page.h1 %>
                  </h2>
                  <% if (page.subheadline) { %>
                    <p class="text-gray-500 mt-1 truncate"><%= page.subheadline %></p>
                  <% } %>
                  <div class="flex items-center gap-3 mt-3">
                    <span class="text-xs px-2.5 py-1 bg-brand-50 text-brand-600 rounded-full font-medium"><%= page.keyword %></span>
                    <span class="text-xs text-gray-400">/<%= page.slug %></span>
                  </div>
                </div>
                <span class="text-gray-300 group-hover:text-brand-600 transition text-xl">&rarr;</span>
              </div>
            </a>
          <% }); %>
        </div>
      <% } %>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-gray-100 py-8">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-sm text-gray-400">&copy; 2026 Nexora. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>
